<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Section color line -->
        <View
            android:id="@+id/view_section_line"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:minHeight="56dp"
            android:background="@color/accent_red"/>

        <!-- Checkbox -->
        <ImageView
            android:id="@+id/iv_checkbox"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_checkbox_unchecked"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"/>

        <!-- Task ner + ogno tsag -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/tv_task_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_primary"
                android:textSize="15sp"/>

            <!-- Ogno + tsagiin medeelel - TaskAdapter-d format hiigdene -->
            <TextView
                android:id="@+id/tv_time_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Edit icon - баруун талд -->
        <ImageView
            android:id="@+id/iv_edit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_edit"
            android:tint="@color/accent_red"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>