<?xml version="1.0" encoding="utf-8"?>
<!--
  ФАЙЛЫН БАЙРШИЛ: res/color/nav_selector.xml
  "color" хавтас байхгүй бол drawable-д байгаа "color" хавтасаа ашиглаж болно
  Эсвэл res > New > Android Resource Directory > color гэж үүсгэ
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Идэвхтэй tab: улаан өнгө -->
    <item android:color="@color/accent_red" android:state_checked="true" />
    <!-- Идэвхгүй tab: саарал өнгө -->
    <item android:color="@color/nav_icon_inactive" />
</selector>