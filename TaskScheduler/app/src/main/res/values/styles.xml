<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextStyle" />
    <style name="CardStyle" />

    <style name="TextStyle.Title">
        <item name="android:fontFamily">@font/cinzel_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="TextStyle.Subtitle">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.15</item>
    </style>

    <style name="TextStyle.CardTitle">
        <item name="android:fontFamily">@font/cinzel_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextStyle.CardSubtitle">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextStyle.SectionHeader">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextStyle.TaskName">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TextStyle.TimeText">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextStyle.MonthTitle">
        <item name="android:fontFamily">@font/cinzel_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">36sp</item>
    </style>

    <style name="TextStyle.DayTitle">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="CardStyle.TaskList">
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="CardStyle.TaskItem">
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="cardCornerRadius">10dp</item>
        <item name="cardElevation">0dp</item>
    </style>

</resources>