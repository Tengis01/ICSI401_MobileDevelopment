<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TaskScheduler" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_red</item>
        <item name="colorPrimaryVariant">@color/accent_red</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>

    <style name="DarkDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:windowBackground">@drawable/shape_dialog_bg</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <!-- Dialog title tekst tsagaan -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <!-- Positive/Negative tovchiin ongo tsagaan - colorAccent override -->
        <item name="colorAccent">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogWhiteButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogWhiteButton</item>
    </style>

    <style name="DialogWhiteButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="rippleColor">@color/accent_red</item>
    </style>

</resources>